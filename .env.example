# ─────────────────────────────────────────────────────────────
# Smart-Doctor-Connect-AI — Environment Variables
# Copy this file to .env and fill in your values.
# On Vercel, add these in Project → Settings → Environment Variables
# ─────────────────────────────────────────────────────────────

# MongoDB Atlas connection string (required for production)
# Get from: https://cloud.mongodb.com → Connect → Drivers → copy the URI
# Replace <username>, <password>, and <cluster> with your actual values
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# OpenRouter API key for AI features
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Secret key for signing tokens (change this to something random and secure)
SECRET_KEY=your-random-secret-key-here

# Set to "production" on Vercel, "development" locally
ENVIRONMENT=production
